# Copy to .env.local and fill in your Supabase project values.
# Settings → API in the Supabase dashboard. Both values are public/client-safe (RLS protects data).
# If these are left empty, the app runs fully on localStorage with seed data (offline-safe demo).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
